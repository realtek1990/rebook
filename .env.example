# ReBook — Configuration
# Copy this file to .env and fill in your API key for your preferred provider.

# ─── Provider: Google Gemini (recommended) ───
GEMINI_API_KEY=your_key_here

# ─── Provider: OpenAI ───
# OPENAI_API_KEY=sk-...

# ─── Provider: Mistral (Magistral) ───
# MISTRAL_API_KEY=your_key_here

# ─── Provider: xAI (Grok) ───
# XAI_API_KEY=xai-...

# ─── Provider: Custom (any OpenAI-compatible API) ───
# LLM_API_KEY=your_key_here
# LLM_BASE_URL=http://localhost:11434/v1/chat/completions

# ─── Optional overrides (apply to any provider) ───
# LLM_MODEL=gemini-3-flash-preview
