#!/bin/bash
# ╔══════════════════════════════════════════════════════════════════════╗
# ║  ReBook — macOS App Bundle launcher (bash wrapper)                  ║
# ║  Ensures Python 3 is available before launching the Python         ║
# ║  bootstrap/installer.                                               ║
# ╚══════════════════════════════════════════════════════════════════════╝
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BOOTSTRAP="${SCRIPT_DIR}/rebook_bootstrap.py"

# ── Find a usable Python 3 interpreter ───────────────────────────────────────
find_python() {
    # 1. Homebrew on Apple Silicon (/opt/homebrew)
    local candidates=()
    for p in /opt/homebrew/bin/python3.1[0-9] /opt/homebrew/bin/python3.9; do
        [[ -x "$p" ]] && candidates+=("$p")
    done
    if (( ${#candidates[@]} )); then
        # Pick the highest version
        printf '%s\n' "${candidates[@]}" | sort -V | tail -1
        return 0
    fi

    # 2. Homebrew on Intel (/usr/local)
    candidates=()
    for p in /usr/local/bin/python3.1[0-9] /usr/local/bin/python3.9; do
        [[ -x "$p" ]] && candidates+=("$p")
    done
    if (( ${#candidates[@]} )); then
        printf '%s\n' "${candidates[@]}" | sort -V | tail -1
        return 0
    fi

    # 3. Xcode Command Line Tools / system python3
    if [[ -x /usr/bin/python3 ]]; then
        # Verify it actually works (not just a shim that triggers install dialog)
        if /usr/bin/python3 -c "import sys; sys.exit(0)" 2>/dev/null; then
            echo "/usr/bin/python3"
            return 0
        fi
    fi

    # 4. Anything in PATH
    if command -v python3 &>/dev/null; then
        local p
        p="$(command -v python3)"
        if "$p" -c "import sys; sys.exit(0)" 2>/dev/null; then
            echo "$p"
            return 0
        fi
    fi

    return 1
}

# ── Try to launch immediately ─────────────────────────────────────────────────
PYTHON3="$(find_python 2>/dev/null || true)"
if [[ -n "$PYTHON3" ]]; then
    exec "$PYTHON3" "$BOOTSTRAP"
fi

# ── Python not found — offer to install ───────────────────────────────────────
CLICKED=$(osascript <<'DIALOG' 2>/dev/null || true
display dialog "ReBook wymaga Python 3, który nie jest zainstalowany na tym Macu." & return & return & "Kliknij \"Zainstaluj\" aby zainstalować Xcode Command Line Tools (zawiera Python 3)." & return & return & "Alternatywnie możesz zainstalować Python ze strony python.org/downloads" with title "ReBook — Brak Python 3" buttons {"Anuluj", "Zainstaluj"} default button "Zainstaluj" with icon caution
DIALOG
)

if [[ "$CLICKED" != *"Zainstaluj"* ]]; then
    exit 0
fi

# ── Trigger Xcode CLT install ─────────────────────────────────────────────────
xcode-select --install 2>/dev/null || true

# Show a waiting dialog — the xcode-select installer runs in background
osascript <<'WAIT_DIALOG' 2>/dev/null || true
display dialog "Instalacja Xcode Command Line Tools została uruchomiona." & return & return & "Poczekaj aż systemowy instalator się zakończy, a następnie kliknij OK aby uruchomić ReBook." with title "ReBook — Instalacja w toku" buttons {"OK"} default button "OK" with icon note
WAIT_DIALOG

# ── Re-check ──────────────────────────────────────────────────────────────────
PYTHON3="$(find_python 2>/dev/null || true)"
if [[ -n "$PYTHON3" ]]; then
    exec "$PYTHON3" "$BOOTSTRAP"
fi

# ── Still no Python — last resort ────────────────────────────────────────────
osascript <<'ERR_DIALOG' 2>/dev/null || true
display dialog "Python 3 nadal nie jest dostępny." & return & return & "Spróbuj jednej z tych metod:" & return & "• Otwórz Terminal i wpisz: xcode-select --install" & return & "• Zainstaluj z: python.org/downloads" & return & "• Zainstaluj via Homebrew: brew install python3" & return & return & "Po instalacji uruchom ReBook ponownie." with title "ReBook — Błąd" buttons {"OK"} default button "OK" with icon stop
ERR_DIALOG

exit 1
