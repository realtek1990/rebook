#!/usr/bin/env python3
"""ReBook — macOS App Bundle launcher with native Cocoa first-run installer."""
import glob
import os
import subprocess
import sys
from pathlib import Path

WORKSPACE = Path.home() / ".pdf2epub-app"
VENV_DIR = WORKSPACE / "env"
VENV_PYTHON = VENV_DIR / "bin" / "python3"
MARKER_STAMP = WORKSPACE / ".marker_installed"
CORE_STAMP = WORKSPACE / ".core_installed"

# Prefer Homebrew Python (3.11+) for fast binary wheels
brew_pythons = glob.glob("/opt/homebrew/bin/python3.*")
built_pythons = [p for p in brew_pythons if "-config" not in p and "-m" not in p]
BASE_PYTHON = sorted(built_pythons)[-1] if built_pythons else sys.executable


def is_core_installed():
    return VENV_DIR.exists() and CORE_STAMP.exists()


def run_app():
    """Launch the native macOS GUI."""
    app_dir = Path(__file__).parent.parent / "Resources" / "app"
    os.chdir(app_dir)
    os.execv(str(VENV_PYTHON), [str(VENV_PYTHON), "native_gui.py"])


# ── If already installed, just run ────────────────────────────────────────
if is_core_installed():
    run_app()

# ─── Bootstrap: ensure PyObjC is available ────────────────────────────────
WORKSPACE.mkdir(parents=True, exist_ok=True)

if not VENV_DIR.exists():
    subprocess.run([BASE_PYTHON, "-m", "venv", str(VENV_DIR)], check=True)

pip_bin = VENV_DIR / "bin" / "pip"

# If we're NOT running under the venv Python, re-exec under it
if os.path.realpath(sys.executable) != os.path.realpath(str(VENV_PYTHON)):
    # First make sure PyObjC is installed in the venv
    try:
        subprocess.run(
            [str(VENV_PYTHON), "-c", "from AppKit import *"],
            check=True, capture_output=True,
        )
    except subprocess.CalledProcessError:
        subprocess.run(
            [str(pip_bin), "install", "pyobjc-framework-Cocoa"],
            check=True,
        )
    # Re-exec this same script under the venv Python
    os.execv(str(VENV_PYTHON), [str(VENV_PYTHON), __file__])


# ─── Native Cocoa Installer with Component Selection ─────────────────────

import objc  # noqa: E402
from AppKit import *  # noqa: E402
from Foundation import *  # noqa: E402

# i18n — add app dir to path so we can import it
import sys as _sys
_app_dir = str(Path(__file__).parent.parent / "Resources" / "app")
if _app_dir not in _sys.path:
    _sys.path.insert(0, _app_dir)
from i18n import t

CORE_PACKAGES = [
    "pyobjc-framework-Cocoa",
    "litellm", "markdown", "ebooklib", "pymupdf",
    "beautifulsoup4", "markdownify",
]

MARKER_PACKAGES = [
    "marker-pdf",
]

INSTALLING = False


class InstallerDelegate(NSObject):
    window = None
    logText = None
    progressBar = None
    installBtn = None
    lightRadio = None
    fullRadio = None
    statusLabel = None
    _queue = None
    _install_marker = False

    def applicationDidFinishLaunching_(self, note):
        import queue
        self._queue = queue.Queue()

        W, H = 620, 540
        PAD = 28
        CW = W - 2 * PAD
        mask = NSTitledWindowMask | NSClosableWindowMask | NSMiniaturizableWindowMask
        self.window = NSWindow.alloc().initWithContentRect_styleMask_backing_defer_(
            NSMakeRect(200, 200, W, H), mask, NSBackingStoreBuffered, False)
        self.window.setTitle_(t("inst_window_title"))
        self.window.center()

        cv = NSView.alloc().initWithFrame_(NSMakeRect(0, 0, W, H))
        self.window.setContentView_(cv)

        top = H - 20

        # ── Title ────────────────────────────────────────────────────
        title = NSTextField.labelWithString_(t("inst_title"))
        title.setFont_(NSFont.systemFontOfSize_weight_(20, 0.5))
        title.setFrame_(NSMakeRect(PAD, top - 30, CW, 28))
        cv.addSubview_(title)
        top -= 40

        subtitle = NSTextField.labelWithString_(t("inst_subtitle"))
        subtitle.setFont_(NSFont.systemFontOfSize_(12))
        subtitle.setTextColor_(NSColor.secondaryLabelColor())
        subtitle.setFrame_(NSMakeRect(PAD, top - 18, CW, 16))
        cv.addSubview_(subtitle)
        top -= 34

        # ── Separator ────────────────────────────────────────────────
        sep = NSBox.alloc().initWithFrame_(NSMakeRect(PAD, top, CW, 1))
        sep.setBoxType_(NSBoxSeparator)
        cv.addSubview_(sep)
        top -= 20

        # ── Section Header ───────────────────────────────────────────
        secHeader = NSTextField.labelWithString_(t("inst_section_header"))
        secHeader.setFont_(NSFont.systemFontOfSize_weight_(11, 0.6))
        secHeader.setTextColor_(NSColor.secondaryLabelColor())
        secHeader.setFrame_(NSMakeRect(PAD, top - 14, CW, 14))
        cv.addSubview_(secHeader)
        top -= 28

        # ── Option 1: Light ──────────────────────────────────────────
        self.lightRadio = NSButton.alloc().initWithFrame_(
            NSMakeRect(PAD, top - 22, CW, 20))
        self.lightRadio.setButtonType_(NSRadioButton)
        self.lightRadio.setTitle_(t("inst_light_title"))
        self.lightRadio.setFont_(NSFont.systemFontOfSize_weight_(14, 0.4))
        self.lightRadio.setState_(NSOnState)
        cv.addSubview_(self.lightRadio)
        top -= 26

        lightDesc = NSTextField.wrappingLabelWithString_(t("inst_light_desc"))
        lightDesc.setFont_(NSFont.systemFontOfSize_(11))
        lightDesc.setTextColor_(NSColor.tertiaryLabelColor())
        lightDesc.setFrame_(NSMakeRect(PAD + 20, top - 78, CW - 20, 74))
        cv.addSubview_(lightDesc)
        top -= 88

        # ── Option 2: Full ───────────────────────────────────────────
        self.fullRadio = NSButton.alloc().initWithFrame_(
            NSMakeRect(PAD, top - 22, CW, 20))
        self.fullRadio.setButtonType_(NSRadioButton)
        self.fullRadio.setTitle_(t("inst_full_title"))
        self.fullRadio.setFont_(NSFont.systemFontOfSize_weight_(14, 0.4))
        self.fullRadio.setState_(NSOffState)
        cv.addSubview_(self.fullRadio)
        top -= 26

        fullDesc = NSTextField.wrappingLabelWithString_(t("inst_full_desc"))
        fullDesc.setFont_(NSFont.systemFontOfSize_(11))
        fullDesc.setTextColor_(NSColor.tertiaryLabelColor())
        fullDesc.setFrame_(NSMakeRect(PAD + 20, top - 78, CW - 20, 74))
        cv.addSubview_(fullDesc)
        top -= 92

        # Link radio buttons together
        self.lightRadio.setTarget_(self)
        self.lightRadio.setAction_("radioChanged:")
        self.fullRadio.setTarget_(self)
        self.fullRadio.setAction_("radioChanged:")

        # ── Separator ────────────────────────────────────────────────
        sep2 = NSBox.alloc().initWithFrame_(NSMakeRect(PAD, top, CW, 1))
        sep2.setBoxType_(NSBoxSeparator)
        cv.addSubview_(sep2)
        top -= 16

        # ── Install Button ───────────────────────────────────────────
        self.installBtn = NSButton.alloc().initWithFrame_(
            NSMakeRect(PAD, top - 38, CW, 38))
        self.installBtn.setBezelStyle_(NSBezelStyleRounded)
        self.installBtn.setTitle_(t("inst_install_btn"))
        self.installBtn.setFont_(NSFont.systemFontOfSize_weight_(14, 0.4))
        self.installBtn.setTarget_(self)
        self.installBtn.setAction_("startInstall:")
        self.installBtn.setKeyEquivalent_("\r")
        cv.addSubview_(self.installBtn)
        top -= 48

        # ── Progress bar ─────────────────────────────────────────────
        self.progressBar = NSProgressIndicator.alloc().initWithFrame_(
            NSMakeRect(PAD, top - 6, CW, 6))
        self.progressBar.setStyle_(NSProgressIndicatorBarStyle)
        self.progressBar.setIndeterminate_(True)
        self.progressBar.setHidden_(True)
        cv.addSubview_(self.progressBar)
        top -= 14

        # ── Status label ─────────────────────────────────────────────
        self.statusLabel = NSTextField.labelWithString_("")
        self.statusLabel.setFont_(NSFont.systemFontOfSize_(11))
        self.statusLabel.setTextColor_(NSColor.secondaryLabelColor())
        self.statusLabel.setFrame_(NSMakeRect(PAD, top - 16, CW, 14))
        cv.addSubview_(self.statusLabel)

        self.window.makeKeyAndOrderFront_(None)
        NSApp.activateIgnoringOtherApps_(True)

    def applicationShouldTerminateAfterLastWindowClosed_(self, app):
        return True

    @objc.IBAction
    def radioChanged_(self, sender):
        if sender == self.lightRadio:
            self.fullRadio.setState_(NSOffState)
            self.lightRadio.setState_(NSOnState)
        else:
            self.lightRadio.setState_(NSOffState)
            self.fullRadio.setState_(NSOnState)

    @objc.IBAction
    def startInstall_(self, sender):
        global INSTALLING
        if INSTALLING:
            return
        INSTALLING = True
        self._install_marker = (self.fullRadio.state() == NSOnState)
        self.installBtn.setEnabled_(False)
        self.lightRadio.setEnabled_(False)
        self.fullRadio.setEnabled_(False)
        self.installBtn.setTitle_(t("inst_installing"))
        self.progressBar.setHidden_(False)
        self.progressBar.startAnimation_(None)
        self.statusLabel.setStringValue_(t("inst_preparing"))

        import threading
        threading.Thread(target=self._doInstall, daemon=True).start()

    @objc.python_method
    def _doInstall(self):
        try:
            # ── Core packages ─────────────────────────────────────
            self._updateStatus(t("inst_core_progress"))
            cmd = [str(pip_bin), "install", "-q"] + CORE_PACKAGES
            proc = subprocess.Popen(
                cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
            for line in proc.stdout:
                if line.strip():
                    self._updateStatus(line.strip()[:80])
            proc.wait()
            if proc.returncode != 0:
                self._updateStatus(t("inst_core_error"))
                self._scheduleUI("_installFailed")
                return

            # Write core stamp
            CORE_STAMP.touch()

            # ── Marker OCR (optional) ─────────────────────────────
            if self._install_marker:
                self._updateStatus(t("inst_marker_progress"))
                cmd2 = [str(pip_bin), "install", "-q"] + MARKER_PACKAGES
                proc2 = subprocess.Popen(
                    cmd2, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
                for line in proc2.stdout:
                    if line.strip():
                        self._updateStatus(line.strip()[:80])
                proc2.wait()
                if proc2.returncode != 0:
                    self._updateStatus(t("inst_marker_warn"))
                else:
                    MARKER_STAMP.touch()

            self._updateStatus(t("inst_done"))
            self._scheduleUI("_installDone")

        except Exception as e:
            self._updateStatus(f"❌ {t('error_prefix')}: {e}")
            self._scheduleUI("_installFailed")

    @objc.python_method
    def _updateStatus(self, msg):
        self._queue.put(("_setStatus", msg))
        self.performSelectorOnMainThread_withObject_waitUntilDone_(
            "processQueue:", None, False)

    @objc.python_method
    def _scheduleUI(self, method):
        self._queue.put((method, None))
        self.performSelectorOnMainThread_withObject_waitUntilDone_(
            "processQueue:", None, False)

    @objc.IBAction
    def processQueue_(self, _):
        while not self._queue.empty():
            method, data = self._queue.get_nowait()
            if method == "_setStatus":
                self.statusLabel.setStringValue_(data)
            elif method == "_installDone":
                self.progressBar.stopAnimation_(None)
                self.progressBar.setHidden_(True)
                self.installBtn.setEnabled_(True)
                self.installBtn.setTitle_(t("inst_launch_btn"))
                self.installBtn.setAction_("launchApp:")
                marker_note = ""
                if not self._install_marker:
                    marker_note = t("inst_marker_hint")
                self.statusLabel.setStringValue_(t("inst_ready") + marker_note)
            elif method == "_installFailed":
                self.progressBar.stopAnimation_(None)
                self.progressBar.setHidden_(True)
                self.installBtn.setEnabled_(True)
                self.installBtn.setTitle_(t("inst_retry_btn"))
                self.installBtn.setAction_("startInstall:")
                self.lightRadio.setEnabled_(True)
                self.fullRadio.setEnabled_(True)
                global INSTALLING
                INSTALLING = False

    @objc.IBAction
    def launchApp_(self, sender):
        self.window.close()
        NSApp.terminate_(None)
        run_app()


if __name__ == "__main__":
    app = NSApplication.sharedApplication()
    app.setActivationPolicy_(NSApplicationActivationPolicyRegular)
    delegate = InstallerDelegate.alloc().init()
    app.setDelegate_(delegate)
    app.run()
    # After installer quits, launch the main app if core is installed
    if is_core_installed():
        run_app()
